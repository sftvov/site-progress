                  use(xlink:href='img/sprite/symbols.svg#' + item.icon)
                h2.t2d !{item.title}
              p.p1 !{item.text}
        .center__num-row.row.wrap.aie.g3
          .col7.aic.n1w2.n3w3.w2.x4w4
            p.a1 800
