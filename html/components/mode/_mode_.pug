mixin modeSvg(icon)
  svg.i24.x2i20
    use(xlink:href=`img/sprite/symbols.svg#${icon}`)

mixin mode(props = {})
  - 
    const {
      tag = 'span',
      text = '',
      icon = 'info',
      iconBefore = false
    } = props

  #{tag}.mode&attributes(attributes)
    if iconBefore
      +modeSvg(icon)
    span.b1 !{text}
    unless iconBefore
      +modeSvg(icon)

mixin modeTooltip(props = {})
  - 
    const {
      tag = 'span',
      text = '',
      toolTipText = '',
    } = props

  span.mode&attributes(attributes)    
    #{tag}.b1(class = (tag === 'a') ? 'mode__link' : false) !{text}
    .tooltip
      span.tooltip__text !{toolTipText}
      +modeSvg('info')